{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "Task Manager",
  "version": "0.2.6",
  "identifier": "com.taskmanager.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Task Manager",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      },
      {
        "label": "cockpit",
        "title": "今日驾驶舱",
        "url": "/?window=cockpit",
        "width": 286,
        "height": 342,
        "minWidth": 286,
        "minHeight": 342,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNEREM5MzlBRDM0NTczNUIKUldSYmMwWFRtcFBjUFRLU0Yra0JkL0F3b1ZCRE53QlN1MmYwcDhwOUZwaHZ0VnBxQlBxN2lId24K",
      "endpoints": [
        "https://github.com/smileQiny/taskmanager/releases/latest/download/latest.json"
      ]
    }
  }
}
